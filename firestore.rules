rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Profiles Collection
    match /profiles/{userId} {
      // Anyone logged in can read a profile (required for browsing and matching)
      allow read: if request.auth != null;
      // Users can only write their own profile
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /privateProfiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /shortlist/{profileId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    match /shareLinks/{shareLinkId} {
      allow read, write: if false;
    }

    // Matches Collection
    match /matches/{matchId} {
      // Users can only read matches where they are the sender or receiver
      allow read: if request.auth != null && (
        resource.data.receiverId == request.auth.uid || 
        resource.data.senderId == request.auth.uid
      );
      
      // Users can only create matches if they are listed as the sender
      allow create: if request.auth != null
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.receiverId is string
        && request.resource.data.receiverId != request.auth.uid
        && request.resource.data.status == "pending";
      
      // Receiver can approve/reject pending requests. Sender can withdraw their own request.
      allow update: if request.auth != null && (
        (
          resource.data.receiverId == request.auth.uid
          && resource.data.status == "pending"
          && request.resource.data.status in ["approved", "rejected"]
          && request.resource.data.senderId == resource.data.senderId
          && request.resource.data.receiverId == resource.data.receiverId
        ) || (
          resource.data.senderId == request.auth.uid
          && request.resource.data.status == "withdrawn"
          && request.resource.data.senderId == resource.data.senderId
          && request.resource.data.receiverId == resource.data.receiverId
        )
      );

      // Message reads are only available to participants after the match is approved.
      // Client-side message writes are disabled; message creation should go through trusted server routes.
      match /messages/{messageId} {
        allow read: if request.auth != null && (
          (
            get(/databases/$(database)/documents/matches/$(matchId)).data.senderId == request.auth.uid ||
            get(/databases/$(database)/documents/matches/$(matchId)).data.receiverId == request.auth.uid
          ) &&
          get(/databases/$(database)/documents/matches/$(matchId)).data.status == "approved"
        );
        allow write: if false;
      }
    }
  }
}
