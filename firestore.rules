rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Profiles Collection
    match /profiles/{userId} {
      // Anyone logged in can read a profile (required for browsing and matching)
      allow read: if request.auth != null;
      // Users can only write their own profile
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Matches Collection
    match /matches/{matchId} {
      // Users can only read matches where they are the sender or receiver
      allow read: if request.auth != null && (
        resource.data.receiverId == request.auth.uid || 
        resource.data.senderId == request.auth.uid
      );
      
      // Users can only create matches if they are listed as the sender
      allow create: if request.auth != null && request.resource.data.senderId == request.auth.uid;
      
      // Either person can update the match (e.g. receiver clicks "approve" or "reject")
      allow update: if request.auth != null && (
        resource.data.receiverId == request.auth.uid || 
        resource.data.senderId == request.auth.uid
      );

      // Secure the messaging stream subcollection using get() to check parent status
      match /messages/{messageId} {
        allow read, write: if request.auth != null && (
          get(/databases/$(database)/documents/matches/$(matchId)).data.senderId == request.auth.uid ||
          get(/databases/$(database)/documents/matches/$(matchId)).data.receiverId == request.auth.uid
        );
      }
    }
  }
}
